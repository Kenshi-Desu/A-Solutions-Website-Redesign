import { apiClient } from "../../api/index";
import { useCrudBase } from "./base/useCrudBase";

import {
  OCRCTimelineResponse,
  OCRCTimelinePostRequest,
  OCRCTimelinePatchRequest,
} from "../../api/api-client";

export function useOCRCTimelines() {
  return useCrudBase<
    OCRCTimelineResponse,
    OCRCTimelinePostRequest,
    OCRCTimelinePatchRequest
  >({
    getAll: () => apiClient.oCRCTimelinesAll(),
    getById: (id) => apiClient.oCRCTimelinesGET(id),
    create: (body) => apiClient.oCRCTimelinesPOST(body),
    update: (id, body) => apiClient.oCRCTimelinesPATCH(id, body),
    remove: (id) => apiClient.oCRCTimelinesDELETE(id),
  });
}
